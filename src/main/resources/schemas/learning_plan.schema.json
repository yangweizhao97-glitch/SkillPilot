{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "summary", "targetRole", "durationWeeks", "weeklyHours", "priorities", "phases", "milestones", "successMetrics"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "summary": {"type": "string", "minLength": 1, "maxLength": 1000},
    "targetRole": {"type": "string", "minLength": 1, "maxLength": 200},
    "durationWeeks": {"type": "integer", "minimum": 1, "maximum": 24},
    "weeklyHours": {"type": "integer", "minimum": 1, "maximum": 40},
    "priorities": {
      "type": "array", "minItems": 1, "maxItems": 8,
      "items": {"type": "object", "additionalProperties": false, "required": ["priority", "skill", "gap", "evidence"], "properties": {
        "priority": {"type": "integer", "minimum": 1, "maximum": 8},
        "skill": {"type": "string", "minLength": 1, "maxLength": 200},
        "gap": {"type": "string", "minLength": 1, "maxLength": 500},
        "evidence": {"type": "string", "minLength": 1, "maxLength": 500}
      }}
    },
    "phases": {
      "type": "array", "minItems": 1, "maxItems": 8,
      "items": {"type": "object", "additionalProperties": false, "required": ["weekStart", "weekEnd", "title", "goals", "actions", "deliverables"], "properties": {
        "weekStart": {"type": "integer", "minimum": 1, "maximum": 24},
        "weekEnd": {"type": "integer", "minimum": 1, "maximum": 24},
        "title": {"type": "string", "minLength": 1, "maxLength": 200},
        "goals": {"type": "array", "minItems": 1, "maxItems": 8, "items": {"type": "string", "minLength": 1, "maxLength": 500}},
        "actions": {"type": "array", "minItems": 1, "maxItems": 12, "items": {"type": "string", "minLength": 1, "maxLength": 500}},
        "deliverables": {"type": "array", "minItems": 1, "maxItems": 8, "items": {"type": "string", "minLength": 1, "maxLength": 500}}
      }}
    },
    "milestones": {"type": "array", "minItems": 1, "maxItems": 12, "items": {"type": "object", "additionalProperties": false, "required": ["week", "outcome", "verification"], "properties": {
      "week": {"type": "integer", "minimum": 1, "maximum": 24},
      "outcome": {"type": "string", "minLength": 1, "maxLength": 500},
      "verification": {"type": "string", "minLength": 1, "maxLength": 500}
    }}},
    "successMetrics": {"type": "array", "minItems": 1, "maxItems": 12, "items": {"type": "string", "minLength": 1, "maxLength": 500}}
  }
}
