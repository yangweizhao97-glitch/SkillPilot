{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "overallScore", "summary", "dimensions", "strengths", "gaps", "actionPlan", "recommendedPracticeQuestions"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "overallScore": {"type": "integer", "minimum": 0, "maximum": 100},
    "summary": {"type": "string", "minLength": 1, "maxLength": 800},
    "dimensions": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "score", "assessment"],
        "properties": {
          "key": {"enum": ["accuracy", "relevance", "depth", "communication"]},
          "label": {"type": "string", "minLength": 1},
          "score": {"type": "integer", "minimum": 0, "maximum": 100},
          "assessment": {"type": "string", "minLength": 1, "maxLength": 300}
        }
      }
    },
    "strengths": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string", "minLength": 1}},
    "gaps": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string", "minLength": 1}},
    "actionPlan": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "action", "reason"],
        "properties": {
          "priority": {"type": "integer", "minimum": 1, "maximum": 5},
          "action": {"type": "string", "minLength": 1, "maxLength": 300},
          "reason": {"type": "string", "minLength": 1, "maxLength": 300}
        }
      }
    },
    "recommendedPracticeQuestions": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"type": "string", "minLength": 1}}
  }
}
