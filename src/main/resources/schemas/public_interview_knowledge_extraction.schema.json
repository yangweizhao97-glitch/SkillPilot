{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["experiences"],
  "properties": {
    "experiences": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["industry", "company", "position", "experienceLevel", "interviewRound", "summary", "tags", "eventDate", "questions"],
        "properties": {
          "industry": {"type": ["string", "null"], "maxLength": 120},
          "company": {"type": ["string", "null"], "maxLength": 255},
          "position": {"type": "string", "minLength": 1, "maxLength": 255},
          "experienceLevel": {"type": ["string", "null"], "maxLength": 120},
          "interviewRound": {"type": ["string", "null"], "maxLength": 120},
          "summary": {"type": "string", "minLength": 1, "maxLength": 4000},
          "tags": {"type": "array", "maxItems": 30, "items": {"type": "string", "maxLength": 80}},
          "eventDate": {"type": ["string", "null"], "format": "date"},
          "questions": {
            "type": "array",
            "minItems": 1,
            "maxItems": 30,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["question", "questionType", "difficulty", "knowledgePoints", "answerOutline", "referenceAnswer", "scoringRubric", "commonMistakes", "followUpCandidates"],
              "properties": {
                "question": {"type": "string", "minLength": 1, "maxLength": 2000},
                "questionType": {"enum": ["TECHNICAL", "PROJECT", "BEHAVIORAL", "SYSTEM_DESIGN"]},
                "difficulty": {"enum": ["EASY", "MEDIUM", "HARD"]},
                "knowledgePoints": {"type": "array", "maxItems": 30, "items": {"type": "string", "maxLength": 300}},
                "answerOutline": {"type": "array", "minItems": 1, "maxItems": 20, "items": {"type": "string", "maxLength": 500}},
                "referenceAnswer": {"type": ["string", "null"], "maxLength": 8000},
                "scoringRubric": {"type": "array", "maxItems": 20, "items": {"type": "object"}},
                "commonMistakes": {"type": "array", "maxItems": 20, "items": {"type": "string", "maxLength": 500}},
                "followUpCandidates": {"type": "array", "maxItems": 20, "items": {"type": "string", "maxLength": 1000}}
              }
            }
          }
        }
      }
    }
  }
}
