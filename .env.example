# CareerAgent local environment

# Application
APP_ENV=local
SERVER_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173

# PostgreSQL + pgvector
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=career_agent
POSTGRES_USER=career_agent
POSTGRES_PASSWORD=career_agent_dev_password
DATABASE_URL=jdbc:postgresql://localhost:5432/career_agent

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
# Replace this in local .env. Never commit real secrets.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_SECONDS=7200

# File upload and local storage
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=20MB
ALLOWED_FILE_TYPES=RESUME,JD,NOTE,PROJECT_DOC

# Alibaba Cloud Model Studio / DashScope
# Put the real key in .env only. Never commit it.
DASHSCOPE_API_KEY=
LLM_PROVIDER=DASHSCOPE
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CHAT_MODEL=qwen-flash
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
LLM_CONNECT_TIMEOUT=5s
LLM_READ_TIMEOUT=60s
LLM_MAX_RETRIES=2

# Agent runtime
AGENT_MAX_RETRIES=2
AGENT_INITIAL_RETRY_DELAY=100ms
AGENT_TASK_THREAD_POOL_SIZE=4
AGENT_HANDOFF_ENABLED=true
AGENT_HANDOFF_MAX_DEPTH=4
TASK_STREAM_THREAD_POOL_SIZE=8
RAG_DEFAULT_TOP_K=8
RAG_MAX_TOP_K=20

# Optional MCP Streamable HTTP server. Disabled unless both the switch and an explicit tool allowlist are set.
MCP_ENABLED=false
MCP_ENDPOINT=
MCP_SERVER_NAME=default
MCP_PROTOCOL_VERSION=2025-06-18
MCP_BEARER_TOKEN=
MCP_CONNECT_TIMEOUT=2s
MCP_READ_TIMEOUT=10s
MCP_MAX_REQUEST_BYTES=65536
MCP_MAX_RESPONSE_BYTES=1048576
MCP_ALLOWED_TOOLS=
MCP_ALLOWED_AGENTS=JOB_MATCH_AGENT,RESUME_ANALYSIS_AGENT,INTERVIEW_QUESTION_AGENT

# Logging and observability
LOG_LEVEL=INFO
ENABLE_JSON_LOGS=true
